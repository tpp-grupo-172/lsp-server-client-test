{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: dependency-graph",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/dependency-graph"
      },
      "problemMatcher": []
    },
    {
      "label": "compile: extension",
      "type": "npm",
      "script": "compile",
      "problemMatcher": ["$tsc"],
      "dependsOn": ["build: dependency-graph"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
